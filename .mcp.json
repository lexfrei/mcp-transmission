{
  "mcpServers": {
    "mcp-transmission": {
      "command": "docker",
      "args": [
        "run", "--rm", "-i",
        "-e", "TRANSMISSION_URL",
        "-e", "TRANSMISSION_USERNAME",
        "-e", "TRANSMISSION_PASSWORD",
        "ghcr.io/lexfrei/mcp-transmission:latest"
      ],
      "env": {
        "TRANSMISSION_URL": "http://host.docker.internal:9091/transmission/rpc"
      }
    }
  }
}
